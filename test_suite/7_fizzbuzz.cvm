show("--- 8. Testing FizzBuzz ---\n");

fn fizzbuzz(n) {
    assume i := 1;
    loop (i <= n) {
        when (i % 15 == 0) {
            show("FizzBuzz\n");
        } 
        elsewhen (i % 3 == 0) {
            show("Fizz\n");
        } 
        elsewhen (i % 5 == 0) {
            show("Buzz\n");
        } 
        otherwise {
            show(i);
            show("\n");
        }
        i := i + 1;
    }
}

fizzbuzz(15);
