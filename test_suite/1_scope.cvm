// tests/1_scope.cvm
show("--- 1. Testing Scope (Local vs Global) ---\n");
assume global_var := 100;

fn test_scope(local_var) {
    assume global_var := 50;
    give local_var + global_var;
}

assume scope_res := test_scope(25);
show("Inside function result (expected 75):");
show(scope_res);
show("\n");
show("Global variable after function (expected 100):");
show(global_var);
