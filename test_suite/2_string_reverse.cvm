// tests/3_string_reverse.cvm
show("--- 3. Testing String Reverse ---\n");

fn reverse_string(str) {
    assume len := length(str);
    assume result := "";
    assume i := len - 1;
    loop (i >= 0) {
        result := result + str[i];
        i := i - 1;
    }
    give result;
}

show("Enter a string to reverse :");
assume s:= ask();
show("Reversed string: ");
show(reverse_string(s));
